        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-3-haiku\",\n  \"max_tokens\": 1000,\n  \"temperature\": 0.5,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un conseiller commercial IA expert en CRM. Analyse les statistiques et génère des insights actionnables.\\n\\nRéponds UNIQUEMENT en JSON valide avec un tableau d'insights:\\n[\\n  {\\n    \\\"id\\\": \\\"insight-1\\\",\\n    \\\"type\\\": \\\"opportunity\\\" ou \\\"task\\\" ou \\\"contact\\\" ou \\\"general\\\",\\n    \\\"title\\\": \\\"titre court\\\",\\n    \\\"description\\\": \\\"description\\\",\\n    \\\"action\\\": \\\"action recommandée\\\",\\n    \\\"priority\\\": \\\"high\\\" ou \\\"medium\\\" ou \\\"low\\\",\\n    \\\"createdAt\\\": \\\"{{ $now.toISO() }}\\\"\\n  }\\n]\\n\\nGénère 3-5 insights pertinents.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Statistiques CRM:\\n\\nOpportunités totales: {{ $json.data.stats.totalOpportunities }}\\nOpportunités actives: {{ $json.data.stats.activeOpportunities }}\\nTâches en attente: {{ $json.data.stats.pendingTasks }}\\nTâches en retard: {{ $json.data.stats.overdueTasks }}\\nContacts: {{ $json.data.stats.totalContacts }}\"\n    }\n  ]\n}",
        "options": {}
