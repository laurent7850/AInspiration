    {
      "parameters": {
        "jsCode": "// Extract et parse la réponse OpenRouter\nconst response = $input.first().json;\n\nlet result;\ntry {\n  // La réponse OpenRouter est dans choices[0].message.content\n  const content = response.choices?.[0]?.message?.content || '';\n  \n  // Essayer d'extraire le JSON\n  const jsonMatch = content.match(/[\\[\\{][\\s\\S]*[\\]\\}]/);\n  if (jsonMatch) {\n    result = JSON.parse(jsonMatch[0]);\n  } else {\n    result = JSON.parse(content);\n  }\n} catch (e) {\n  // Retourner la réponse brute en cas d'erreur\n  result = { \n    error: 'Parse error', \n    raw: response.choices?.[0]?.message?.content || response \n  };\n}\n\nreturn [{ json: result }];"
      },
