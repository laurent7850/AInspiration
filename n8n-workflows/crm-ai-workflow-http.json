        "jsonBody": "={\n  \"model\": \"anthropic/claude-3-haiku\",\n  \"max_tokens\": 800,\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un analyste commercial. Analyse l'opportunité.\\n\\nRéponds en JSON:\\n{\\n  \\\"analysis\\\": \\\"analyse\\\",\\n  \\\"recommendations\\\": [\\\"rec1\\\", \\\"rec2\\\"],\\n  \\\"riskLevel\\\": \\\"low\\\" ou \\\"medium\\\" ou \\\"high\\\"\\n}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Opportunité: {{ $json.data.opportunity.name }}\\nÉtape: {{ $json.data.opportunity.stage }}\\nValeur: {{ $json.data.opportunity.estimated_value || 0 }}€\"\n    }\n  ]\n}",
