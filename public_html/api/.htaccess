# Activation du module rewrite
RewriteEngine On

# Autoriser l'accès
Order Allow,Deny
Allow from all

# Configuration CORS
Header set Access-Control-Allow-Origin "https://ainspiration.eu"
Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
Header set Access-Control-Allow-Headers "Content-Type, Authorization"
Header set Access-Control-Allow-Credentials "true"

# Gestion des requêtes OPTIONS pour CORS
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Redirection vers le serveur Node.js
RewriteRule ^(.*)$ http://localhost:5000/api/$1 [P,L]

# En cas d'erreur de proxy
ErrorDocument 503 "Service temporairement indisponible"